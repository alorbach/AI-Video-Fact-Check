HOST=127.0.0.1
PORT=3847

# openai | anthropic | gemini  (only openai implemented in Level 3)
LLM_PROVIDER=openai

# Never commit real keys. Extension must never receive these.
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Retention (seconds); 0 = delete ASAP after processing
AUDIO_RETENTION_SECONDS=0
TRANSCRIPT_RETENTION_SECONDS=86400
